@page
@using FoodSafetyTracker.Areas.Identity.Pages.Account
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "/Views/Shared/_Layout.cshtml";
}
<div class="window-title" style="margin-top: 20px;">
    SYSTEM LOGIN
    <div class="window-dots">
        <div class="window-dot">_</div>
        <div class="window-dot">□</div>
        <div class="window-dot">×</div>
    </div>
</div>

<div style="max-width: 480px; margin: 0 auto;">
    <div class="gov-panel">
        <div class="gov-panel-header">ENTER CREDENTIALS</div>

        <form id="account" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:14px;"></div>

            <div class="form-group">
                <label asp-for="Input.Email" class="form-label">EMAIL</label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password" class="form-label">PASSWORD</label>
                <input asp-for="Input.Password" type="password" class="form-control" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-bottom: 16px; display:flex; align-items:center; gap:10px;">
                <input asp-for="Input.RememberMe" type="checkbox" style="width:16px; height:16px;" />
                <label asp-for="Input.RememberMe" style="margin:0; font-size:13px;">REMEMBER ME</label>
            </div>

            <button type="submit" class="btn btn-primary">LOGIN</button>
        </form>

        <div style="margin-top: 16px; border-top: 1px solid #808080; padding-top: 14px; font-size: 13px;">
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register new account</a>
            &nbsp;|&nbsp;
            <a asp-page="./ForgotPassword">Forgot password?</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
