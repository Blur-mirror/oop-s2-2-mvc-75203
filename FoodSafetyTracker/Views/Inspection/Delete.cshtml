@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = "Delete Inspection";
}

<h2>Delete Inspection</h2>
<p>Delete inspection at <strong>@Model.Premises.Name</strong> on <strong>@Model.InspectionDate.ToString("dd MMM        yyyy")</strong>?</p>
<p class="text-danger">This will also delete all associated follow-ups.</p>

<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-controller="Premises" asp-action="Details" asp-route-id="@Model.PremisesId"
       class="btn btn-secondary">Cancel</a>
</form>
