@model IEnumerable<FoodSafetyTracker.Models.Premises>
@{
    ViewData["Title"] = "Premises";
}

<h2>Premises</h2>

@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Add Premises</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Town</th>
            <th>Risk</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Address</td>
                <td>@p.Town</td>
                <td>
                    <span
                        class="badge bg-@(p.RiskRating == FoodSafetyTracker.Models.RiskRating.High ? "danger" :
                                                                                                                                     p.RiskRating == FoodSafetyTracker.Models.RiskRating.Medium ? "warning" : "success")">
                        @p.RiskRating
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-info">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
