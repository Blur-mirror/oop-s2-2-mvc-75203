@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "Delete Follow-Up";
}

<h2>Delete Follow-Up</h2>
<p>Delete follow-up for inspection at <strong>@Model.Inspection.Premises.Name</strong>, due
    <strong>@Model.DueDate.ToString("dd MMM yyyy")</strong>?
</p>

<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-controller="Inspection" asp-action="Details" asp-route-id="@Model.InspectionId"
       class="btn btn-secondary">Cancel</a>
</form>
