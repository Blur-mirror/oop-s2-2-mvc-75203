@model FoodSafetyTracker.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="window-title" style="margin-top: 20px;">
    DASHBOARD — @DateTime.Now.ToString("MMMM yyyy").ToUpper()
    <div class="window-dots">
        <div class="window-dot">_</div>
        <div class="window-dot">□</div>
        <div class="window-dot">×</div>
    </div>
</div>

@* ── Filter Bar ─────────────────────────────────────── *@
<form method="get" asp-action="Index">
    <div class="filter-bar">
        <span class="filter-label">TOWN:</span>
        <select name="town" class="form-select" style="width:auto; min-width:140px;">
            <option value="">ALL TOWNS</option>
            @foreach (var t in Model.Towns)
            {
                <option value="@t" selected="@(Model.SelectedTown == t)">
                    @t.ToUpper()
                </option>
            }
        </select>

        <span class="filter-label">RISK:</span>
        <select name="riskRating" class="form-select" style="width:auto; min-width:140px;">
            <option value="">ALL RATINGS</option>
            @foreach (FoodSafetyTracker.Models.RiskRating r in
                                    Enum.GetValues(typeof(FoodSafetyTracker.Models.RiskRating)))
            {
                <option value="@((int)r)" selected="@(Model.SelectedRiskRating == r)">
                    @r.ToString().ToUpper()
                </option>
            }
        </select>

        <button type="submit" class="btn btn-primary">APPLY FILTER</button>
        @if (Model.SelectedTown != null || Model.SelectedRiskRating != null)
        {
            <a asp-action="Index" class="btn btn-secondary">CLEAR</a>
        }
    </div>
</form>

@* ── Stat Cards ─────────────────────────────────────── *@
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Inspections This Month</div>
        <div class="stat-value">@Model.InspectionsThisMonth.ToString("D2")</div>
    </div>
    <div class="stat-card warn">
        <div class="stat-label">Failed This Month</div>
        <div class="stat-value">@Model.FailedInspectionsThisMonth.ToString("D2")</div>
    </div>
    <div class="stat-card danger">
        <div class="stat-label">Overdue Follow-Ups</div>
        <div class="stat-value">@Model.OverdueOpenFollowUps.ToString("D2")</div>
    </div>
</div>

@* ── Recent Failed Inspections ───────────────────────── *@
<div class="gov-panel">
    <div class="gov-panel-header">RECENT FAILED INSPECTIONS</div>
    @if (Model.RecentFailedInspections.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>PREMISES</th>
                    <th>TOWN</th>
                    <th>DATE</th>
                    <th>SCORE</th>
                    <th>RISK</th>
                    <th>ACTION</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model.RecentFailedInspections)
                {
                    var riskClass = i.Premises.RiskRating switch
                    {
                        FoodSafetyTracker.Models.RiskRating.High => "badge-high",
                        FoodSafetyTracker.Models.RiskRating.Medium => "badge-medium",
                        _ => "badge-low"
                    };
                    <tr>
                        <td>@i.Premises.Name</td>
                        <td>@i.Premises.Town</td>
                        <td>@i.InspectionDate.ToString("dd MMM yyyy")</td>
                        <td>@i.Score / 100</td>
                        <td><span class="badge @riskClass">@i.Premises.RiskRating.ToString().ToUpper()</span></td>
                        <td>
                            <a asp-controller="Inspection" asp-action="Details" asp-route-id="@i.Id"
                               class="btn btn-secondary btn-sm">VIEW</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="color:#444488; font-size:12px; letter-spacing:1px;">NO FAILED INSPECTIONS — SYSTEM CLEAR</p>
    }
</div>

@* ── Overdue Follow-Ups ──────────────────────────────── *@
<div class="gov-panel">
    <div class="gov-panel-header">OVERDUE FOLLOW-UPS</div>
    @if (Model.OverdueFollowUpsList.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>PREMISES</th>
                    <th>INSPECTION DATE</th>
                    <th>DUE DATE</th>
                    <th>DAYS OVERDUE</th>
                    <th>ACTION</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model.OverdueFollowUpsList)
                {
                    var daysOverdue = (DateTime.Today - f.DueDate).Days;
                    <tr>
                        <td>@f.Inspection.Premises.Name</td>
                        <td>@f.Inspection.InspectionDate.ToString("dd MMM yyyy")</td>
                        <td>@f.DueDate.ToString("dd MMM yyyy")</td>
                        <td><span class="badge badge-overdue">+@daysOverdue DAYS</span></td>
                        <td>
                            <a asp-controller="FollowUp" asp-action="Edit" asp-route-id="@f.Id"
                               class="btn btn-primary btn-sm">RESOLVE</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="color:#44ff88; font-size:12px; letter-spacing:1px;">■ NO OVERDUE FOLLOW-UPS — ALL CLEAR</p>
    }
</div>

@* ── Status Bar ──────────────────────────────────────── *@
<div class="status-bar">
    <span>SYS: ONLINE</span>
    <span>DB: foodsafety.db</span>
    <span>USER: @User.Identity?.Name?.ToUpper()</span>
    @if (Model.SelectedTown != null || Model.SelectedRiskRating != null)
    {
        <span>FILTER: @(Model.SelectedTown?.ToUpper() ?? "ALL") / @(Model.SelectedRiskRating?.ToString().ToUpper() ??
                                "ALL")</span>
        }
        <span style="margin-left:auto">@DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")<span class="cursor"></span></span>
    </div>
