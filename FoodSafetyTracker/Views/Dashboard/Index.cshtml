@model FoodSafetyTracker.Models.DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<h2>Dashboard</h2>

<!-- Filter form -->
<form method="get" asp-action="Index" class="row g-3 mb-4">
    <div class="col-auto">
        <label class="form-label">Town</label>
        <select name="town" class="form-select">
            <option value="">All Towns</option>
            @foreach (var t in Model.Towns)
            {
                <option value="@t" selected="@(Model.SelectedTown == t)">@t</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label">Risk Rating</label>
        <select name="riskRating" class="form-select">
            <option value="">All Ratings</option>
            @foreach (var r in Enum.GetValues<FoodSafetyTracker.Models.RiskRating>())
            {
                <option value="@((int)r)" selected="@(Model.SelectedRiskRating == r)">@r</option>
            }
        </select>
    </div>
    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.SelectedTown) || Model.SelectedRiskRating.HasValue)
{
    <div class="alert alert-info">
        Filtering by:
        @if (!string.IsNullOrEmpty(Model.SelectedTown)) { <strong>Town: @Model.SelectedTown</strong> }
        @if (Model.SelectedRiskRating.HasValue) { <strong> Risk: @Model.SelectedRiskRating</strong> }
    </div>
}

<!-- Stat cards -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Inspections This Month</h5>
                <p class="display-4">@Model.InspectionsThisMonth</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger">
            <div class="card-body">
                <h5 class="card-title">Failed This Month</h5>
                <p class="display-4">@Model.FailedInspectionsThisMonth</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">Overdue Open Follow-Ups</h5>
                <p class="display-4">@Model.OverdueOpenFollowUps</p>
            </div>
        </div>
    </div>
</div>

<!-- Overdue follow-ups table -->
<h4>Overdue Follow-Ups</h4>
@if (!Model.OverdueFollowUpsList.Any())
{
    <p class="text-muted">No overdue follow-ups.</p>
}
else
{
    <table class="table table-bordered table-sm mb-4">
        <thead class="table-danger">
            <tr><th>Premises</th><th>Town</th><th>Risk</th><th>Due Date</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var f in Model.OverdueFollowUpsList)
        {
            <tr>
                <td>@f.Inspection.Premises.Name</td>
                <td>@f.Inspection.Premises.Town</td>
                <td>@f.Inspection.Premises.RiskRating</td>
                <td class="text-danger fw-bold">@f.DueDate.ToString("dd MMM yyyy")</td>
                <td><a asp-controller="FollowUp" asp-action="Details" asp-route-id="@f.Id" class="btn btn-sm btn-outline-danger">View</a></td>
            </tr>
        }
        </tbody>
    </table>
}

<!-- Recent failed inspections table -->
<h4>Recent Failed Inspections</h4>
@if (!Model.RecentFailedInspections.Any())
{
    <p class="text-muted">No failed inspections.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-warning">
            <tr><th>Premises</th><th>Town</th><th>Risk</th><th>Date</th><th>Score</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var i in Model.RecentFailedInspections)
        {
            <tr>
                <td>@i.Premises.Name</td>
                <td>@i.Premises.Town</td>
                <td>@i.Premises.RiskRating</td>
                <td>@i.InspectionDate.ToString("dd MMM yyyy")</td>
                <td>@i.Score</td>
                <td><a asp-controller="Inspection" asp-action="Details" asp-route-id="@i.Id" class="btn btn-sm btn-outline-warning">View</a></td>
            </tr>
        }
        </tbody>
    </table>
}
