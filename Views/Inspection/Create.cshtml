@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = "New Inspection";
}

<h2>New Inspection</h2>
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="PremisesId" class="form-label">Premises</label>
        <select asp-for="PremisesId" asp-items="ViewBag.PremisesList" class="form-select">
            <option value="">-- Select --</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="InspectionDate" class="form-label"></label>
        <input asp-for="InspectionDate" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Score" class="form-label">Score (0–100)</label>
        <input asp-for="Score" type="number" min="0" max="100" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Outcome" class="form-label"></label>
        <select asp-for="Outcome" asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Models.InspectionOutcome>()"
                class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
