@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "Follow-Up Details";
}

<h2>Follow-Up</h2>
<p><strong>Inspection:</strong> @Model.Inspection.Premises.Name — @Model.Inspection.InspectionDate.ToString("dd MMM    yyyy")</p>
<p><strong>Due Date:</strong> @Model.DueDate.ToString("dd MMM yyyy")</p>
<p>
    <strong>Status:</strong>
    <span
        class="badge bg-@(Model.Status == FoodSafetyTracker.Models.FollowUpStatus.Closed ? "success" : (Model.DueDate < DateTime.Today ? "danger" : "warning"))">
        @Model.Status
    </span>
</p>
@if (Model.ClosedDate.HasValue)
{
    <p><strong>Closed:</strong> @Model.ClosedDate.Value.ToString("dd MMM yyyy")</p>
}

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
}
<a asp-controller="Inspection" asp-action="Details" asp-route-id="@Model.InspectionId"
   class="btn btn-secondary">Back</a>
