@model FoodSafetyTracker.Models.Premises
@{
    ViewData["Title"] = Model.Name;
}

<h2>@Model.Name</h2>
<p><strong>Address:</strong> @Model.Address, @Model.Town</p>
<p><strong>Risk Rating:</strong> @Model.RiskRating</p>

<h4 class="mt-4">Inspections</h4>
@if (!Model.Inspections.Any())
{
    <p>No inspections recorded.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Score</th>
                <th>Outcome</th>
                <th>Notes</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var i in Model.Inspections.OrderByDescending(x => x.InspectionDate))
            {
                <tr>
                    <td>@i.InspectionDate.ToString("dd MMM yyyy")</td>
                    <td>@i.Score</td>
                    <td>
                        <span
                            class="badge bg-@(i.Outcome == FoodSafetyTracker.Models.InspectionOutcome.Pass ? "success" : "danger")">
                            @i.Outcome
                        </span>
                    </td>
                    <td>@i.Notes</td>
                    <td><a asp-controller="Inspection" asp-action="Details" asp-route-id="@i.Id"
                               class="btn btn-sm btn-info">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <a asp-action="Index" class="btn btn-secondary mt-2">Back</a>
